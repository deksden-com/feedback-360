# Local PostgreSQL connection string for database scripts.
# For Supabase cloud prefer SUPABASE_DB_POOLER_URL (Session pooler).
DATABASE_URL=postgres://postgres:postgres@localhost:5432/feedback360
SUPABASE_DB_POOLER_URL=
AI_WEBHOOK_SECRET=replace-with-long-random-secret

# Preferred for Supabase cloud scripts (avoids direct DB IPv6/host limitations):
# SUPABASE_DB_POOLER_URL=postgresql://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:5432/postgres?sslmode=require&uselibpqcompat=true

# ---------------------------------------------------------------------------
# DNS notes (non-secret): Resend domain authentication records for `go360go.ru`
# Add these records once the domain is delegated to Vercel nameservers.
#
# DKIM:
#   Type: TXT
#   Name: resend._domainkey
#   Value: p=MIGfMA0GCSqGSIb3DQEBAQUAA4GNADCBiQKBgQDDH91pgwwRvxJm3MpDwylu2pHdGyc8bhBmQSpo/K2BjKTini39zYewVeKwQLKG/TLOUgzu8dp3gcGZHNgXc75o/4Secje3z8lEdkI0ih32ctEPXlle1jqI+0bOPqiElwPkyj52Q5BBJzejb8myTCh2F+CRMdMP5TunH+X/QsP/CQIDAQAB
#
# SPF / MAIL FROM subdomain `send.go360go.ru`:
#   Type: MX
#   Name: send
#   Value: feedback-smtp.us-east-1.amazonses.com
#   Priority: 10
#   Type: TXT
#   Name: send
#   Value: v=spf1 include:amazonses.com ~all
#
# DMARC (MVP):
#   Type: TXT
#   Name: _dmarc
#   Value: v=DMARC1; p=none;
#
# SimpleLogin domain verification (public TXT):
#   Type: TXT
#   Name: @
#   Value: sl-verification=huyfnasbfreflxnkwipwryqcjzbqcz
#
# SimpleLogin inbound / aliases (DNS):
#   Type: MX
#   Name: @
#   Priority: 10
#   Value: mx1.simplelogin.co.
#   Type: MX
#   Name: @
#   Priority: 20
#   Value: mx2.simplelogin.co.
#
# SimpleLogin DKIM (CNAME):
#   Type: CNAME
#   Name: dkim._domainkey
#   Value: dkim._domainkey.simplelogin.co.
#   Type: CNAME
#   Name: dkim02._domainkey
#   Value: dkim02._domainkey.simplelogin.co.
#   Type: CNAME
#   Name: dkim03._domainkey
#   Value: dkim03._domainkey.simplelogin.co.
#
# DMARC (hardened by SimpleLogin guidance):
#   Type: TXT
#   Name: _dmarc
#   Value: v=DMARC1; p=quarantine; pct=100; adkim=s; aspf=s
#
# SimpleLogin SPF (root):
#   Type: TXT
#   Name: @
#   Value: v=spf1 include:simplelogin.co ~all
