{
  "name": "@feedback-360/client",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": "./src/index.ts",
  "scripts": {
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "cross-env FEEDBACK360_SKIP_DB_TESTS=1 vitest run",
    "test:db": "vitest run --testTimeout=45000 --maxWorkers=1 --no-file-parallelism src/ft-0021-multi-tenant.test.ts",
    "test:db:full": "vitest run --testTimeout=45000 --maxWorkers=1 --no-file-parallelism src/ft-0021-multi-tenant.test.ts"
  },
  "dependencies": {
    "@feedback-360/api-contract": "workspace:*",
    "@feedback-360/core": "workspace:*",
    "@feedback-360/db": "workspace:*"
  }
}
