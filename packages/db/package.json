{
  "name": "@feedback-360/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": "./src/index.ts",
  "scripts": {
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "cross-env FEEDBACK360_SKIP_DB_TESTS=1 vitest run",
    "test:db": "vitest run --testTimeout=45000 --maxWorkers=1 --no-file-parallelism src/migrations/ft-0002-migrations-health.test.ts src/migrations/ft-0023-rls-smoke.test.ts src/migrations/ft-0091-db-integration-isolation.test.ts src/ft/ft-0085-identity-provision.test.ts src/ft/ft-0201-xe-run-lifecycle.test.ts",
    "test:db:full": "vitest run --testTimeout=45000 --maxWorkers=1 --no-file-parallelism src/migrations src/ft",
    "db:migrate": "tsx src/scripts/migrate.ts",
    "db:health": "tsx src/scripts/health.ts"
  },
  "dependencies": {
    "@feedback-360/api-contract": "workspace:*",
    "drizzle-orm": "0.44.5",
    "dotenv": "17.2.3",
    "pg": "8.16.3"
  },
  "devDependencies": {
    "@types/pg": "8.15.5",
    "drizzle-kit": "0.31.5",
    "tsx": "4.20.6"
  }
}
